{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Folio",
  "version": "0.1.0",
  "identifier": "com.folio.reader",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\dev-tauri.ps1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:VITE_API_BASE='http://127.0.0.1:8000'; npm --prefix frontend run build\"",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Folio",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [],
    "resources": ["resources/**"]
  }
}
